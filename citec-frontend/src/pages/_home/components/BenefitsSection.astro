---
import BenefitCard from "@/components/sections/BenefitCard.astro";
import Button from "@/components/ui/Button.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { benefits } from "@/data/benefits";
---

<section class="bg-white/62 px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeader
        eyebrow="Beneficios"
        title="Afiliacion con valor editorial, relacional y comercial."
        description="CITEC debe mostrar beneficios claros, medibles y conectados a decisiones reales del ecosistema."
      />
      <div data-reveal>
        <Button href="/beneficios/" variant="secondary">Explorar beneficios</Button>
      </div>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {benefits.map((benefit) => <BenefitCard benefit={benefit} />)}
    </div>
  </div>
</section>
