---
import InteractiveStats from "@/islands/InteractiveStats";
import SectionHeader from "@/components/ui/SectionHeader.astro";
---

<section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.95fr_0.65fr] lg:items-center">
    <div>
      <SectionHeader
        eyebrow="Producto institucional"
        title="Una web pensada como infraestructura de valor, no como vitrina estatica."
        description="La experiencia combina contenido claro, rutas escalables, movimiento sobrio y puntos de conversion para que CITEC opere como hub del ecosistema."
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          [
            ["Visibilidad", "Empresas y aliados aparecen dentro de una experiencia curada y facil de descubrir."],
            ["Inteligencia", "Pulse convierte regulacion, mercado y talento en lecturas ejecutivas accionables."],
            ["Relacionamiento", "Mesas, eventos y beneficios conectan al ecosistema con oportunidades concretas."],
          ].map(([title, description]) => (
            <article class="rounded-lg border border-citec-line/80 bg-white/78 p-4 shadow-[0_14px_34px_rgba(13,39,66,0.06)]" data-reveal>
              <h3 class="text-sm font-black text-citec-ink">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-citec-ink-soft">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
    <div data-reveal data-reveal-delay="0.12">
      <InteractiveStats client:visible />
    </div>
  </div>
</section>
