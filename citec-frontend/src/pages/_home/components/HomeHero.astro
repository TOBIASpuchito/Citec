---
import ParticlesToMap from "@/islands/ParticlesToMap";
---

<section class="home-hero text-primary-text" data-home-hero>
  <div class="home-hero__ambient"></div>
  <div class="home-hero__rings"></div>
  <div class="home-hero__fade"></div>

  <ParticlesToMap client:load />

  <div class="home-hero__content">
    <div class="home-hero__copy">
      <h1 class="home-hero__heading font-display" data-reveal data-reveal-delay="0.04">
        <span>Impulsamos</span>
        <span class="home-hero__heading-accent">la innovación</span>
        <span>que conecta</span>
      </h1>
      <p class="home-hero__subtitle" data-reveal data-reveal-delay="0.08">
        Conectamos empresas, academia y gobierno para transformar ideas en impacto real.
      </p>
      <div class="home-hero__actions" data-reveal data-reveal-delay="0.12">
        <a href="/unete/" class="citec-button citec-button--primary">
          Afiliate
          <span aria-hidden="true" class="citec-icon citec-icon--arrow"></span>
        </a>
        <a href="/la-citec/" class="citec-button citec-button--secondary">
          Conoce la CITEC
          <span aria-hidden="true" class="citec-icon citec-icon--arrow"></span>
        </a>
      </div>
      <span class="home-hero__rule" data-reveal data-reveal-delay="0.16"></span>
    </div>
  </div>
</section>
