---
import Button from "@/components/ui/Button.astro";
import { site } from "@/data/site";

const puzzlePieces = [
  {
    label: "Socios",
    detail: "Empresas tech",
    tone: "navy",
    position: "piece-a",
    startX: -180,
    startY: 84,
    startZ: 180,
    startRotateX: -24,
    startRotateY: 38,
  },
  {
    label: "Academia",
    detail: "Talento",
    tone: "cyan",
    position: "piece-b",
    startX: 72,
    startY: -158,
    startZ: 220,
    startRotateX: 34,
    startRotateY: -26,
  },
  {
    label: "Gobierno",
    detail: "Agenda publica",
    tone: "violet",
    position: "piece-c",
    startX: 210,
    startY: 42,
    startZ: 190,
    startRotateX: -20,
    startRotateY: -42,
  },
  {
    label: "Pulse",
    detail: "Criterio",
    tone: "warm",
    position: "piece-d",
    startX: -82,
    startY: 176,
    startZ: 210,
    startRotateX: 42,
    startRotateY: 24,
  },
  {
    label: "Eventos",
    detail: "Conexion",
    tone: "blue",
    position: "piece-e",
    startX: 168,
    startY: 164,
    startZ: 170,
    startRotateX: 22,
    startRotateY: -34,
  },
];
---

<section class="relative isolate overflow-hidden border-b border-citec-line/70 bg-citec-paper">
  <div class="soft-grid pointer-events-none absolute inset-0 opacity-60"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-28 border-b border-white/60 bg-white/70"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(180deg,rgba(247,251,253,0),rgba(255,255,255,0.88))]"></div>

  <div class="relative mx-auto grid min-h-[86svh] w-full max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[0.9fr_1fr] lg:items-center lg:px-8 lg:py-20">
    <div class="max-w-3xl">
      <p class="editorial-label" data-reveal>Camara de Innovacion y Tecnologia Ecuatoriana</p>
      <h1 class="mt-6 font-display text-5xl font-black leading-[1.02] tracking-normal text-citec-ink sm:text-6xl lg:text-7xl" data-reveal data-reveal-delay="0.04">
        La CITEC conecta el ecosistema tecnologico del Ecuador.
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-citec-ink-soft sm:text-lg" data-reveal data-reveal-delay="0.08">
        Representamos al sector de software, innovacion y tecnologias de la informacion. Vinculamos empresas, academia y gobierno para crear agenda, confianza y oportunidades reales de transformacion digital.
      </p>
      <p class="mt-5 max-w-2xl text-base leading-8 text-citec-ink-soft sm:text-lg" data-reveal data-reveal-delay="0.12">
        Una plataforma institucional para descubrir socios, anticipar senales regulatorias y activar colaboracion entre los actores que mueven la industria tech.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row" data-reveal data-reveal-delay="0.16">
        <Button href="/unete/" size="lg">Unete a CITEC</Button>
        <Button href="/socios/" variant="secondary" size="lg">Explorar socios</Button>
      </div>
      <div class="mt-10 grid max-w-3xl gap-3 sm:grid-cols-3" data-reveal data-reveal-delay="0.2">
        {site.stats.map((stat) => (
          <div class="rounded-lg border border-citec-line/80 bg-white/78 p-4 shadow-[0_18px_44px_rgba(13,39,66,0.08)] backdrop-blur-xl">
            <p class="font-display text-2xl font-black text-citec-ink">{stat.value}</p>
            <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-citec-ink-soft">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="relative min-h-[460px] lg:min-h-[620px]" data-hero-puzzle>
      <div class="puzzle-shell" aria-label="Piezas 3D que conectan socios, academia, gobierno, Pulse y eventos dentro de CITEC" role="img">
        <div class="puzzle-stage">
          <div class="puzzle-shadow" aria-hidden="true"></div>
          <div class="puzzle-core" data-puzzle-core>
            <span class="core-eyebrow">Agenda comun</span>
            <strong>CITEC</strong>
            <span>ecosistema tech</span>
          </div>

          <div class="connector connector-a" data-puzzle-connector></div>
          <div class="connector connector-b" data-puzzle-connector></div>
          <div class="connector connector-c" data-puzzle-connector></div>

          {puzzlePieces.map((piece) => (
            <div
              class:list={["puzzle-piece", piece.tone, piece.position]}
              data-puzzle-piece
              data-start-x={piece.startX}
              data-start-y={piece.startY}
              data-start-z={piece.startZ}
              data-start-rotate-x={piece.startRotateX}
              data-start-rotate-y={piece.startRotateY}
            >
              <span class="piece-depth"></span>
              <span class="piece-face">
                <span class="piece-tab tab-right"></span>
                <span class="piece-tab tab-bottom"></span>
                <span class="piece-cut cut-left"></span>
                <span class="piece-cut cut-top"></span>
                <span class="piece-copy">
                  <strong>{piece.label}</strong>
                  <span>{piece.detail}</span>
                </span>
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "@/lib/gsap";

  const initHomeHeroPuzzle = () => {
    const hero = document.querySelector<HTMLElement>("[data-hero-puzzle]");

    if (!hero || hero.dataset.puzzleReady === "true") {
      return;
    }

    hero.dataset.puzzleReady = "true";

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const pieces = gsap.utils.toArray<HTMLElement>("[data-puzzle-piece]", hero);
    const connectors = gsap.utils.toArray<HTMLElement>("[data-puzzle-connector]", hero);
    const core = hero.querySelector<HTMLElement>("[data-puzzle-core]");

    if (reduceMotion) {
      gsap.set([core, ...pieces, ...connectors], { autoAlpha: 1, clearProps: "transform" });
      return;
    }

    gsap.set(pieces, {
      transformPerspective: 980,
      transformStyle: "preserve-3d",
      autoAlpha: 0,
    });
    gsap.set(connectors, { scaleX: 0, transformOrigin: "left center", autoAlpha: 0 });

    const timeline = gsap.timeline({ defaults: { ease: "power3.out" } });

    timeline
      .fromTo(
        core,
        { autoAlpha: 0, y: 34, z: 90, rotateX: 18, rotateY: -12 },
        { autoAlpha: 1, y: 0, z: 0, rotateX: 0, rotateY: 0, duration: 0.9 },
      )
      .to(connectors, { autoAlpha: 1, scaleX: 1, duration: 0.7, stagger: 0.08 }, "-=0.35")
      .fromTo(
        pieces,
        {
          x: (_, piece) => Number((piece as HTMLElement).dataset.startX),
          y: (_, piece) => Number((piece as HTMLElement).dataset.startY),
          z: (_, piece) => Number((piece as HTMLElement).dataset.startZ),
          rotateX: (_, piece) => Number((piece as HTMLElement).dataset.startRotateX),
          rotateY: (_, piece) => Number((piece as HTMLElement).dataset.startRotateY),
          rotateZ: (_, piece) => (Number((piece as HTMLElement).dataset.startX) > 0 ? 8 : -8),
          autoAlpha: 0,
        },
        {
          x: 0,
          y: 0,
          z: 0,
          rotateX: 0,
          rotateY: 0,
          rotateZ: 0,
          autoAlpha: 1,
          duration: 1.1,
          stagger: 0.12,
        },
        "-=0.35",
      )
      .to(pieces, {
        y: (index) => (index % 2 === 0 ? -8 : 7),
        rotateY: (index) => (index % 2 === 0 ? 3 : -3),
        rotateX: (index) => (index % 2 === 0 ? -2 : 2),
        duration: 2.8,
        ease: "sine.inOut",
        repeat: -1,
        yoyo: true,
        stagger: 0.18,
      });
  };

  initHomeHeroPuzzle();
  document.addEventListener("astro:after-swap", initHomeHeroPuzzle);
</script>

<style>
  .puzzle-shell {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    perspective: 1200px;
  }

  .puzzle-stage {
    position: relative;
    width: min(100%, 620px);
    aspect-ratio: 1 / 0.94;
    transform-style: preserve-3d;
    transform: rotateX(58deg) rotateZ(-12deg);
  }

  .puzzle-shadow {
    position: absolute;
    inset: 18% 8% 12% 8%;
    border-radius: 32px;
    background: rgba(7, 21, 38, 0.14);
    filter: blur(34px);
    transform: translateZ(-110px);
  }

  .puzzle-core,
  .puzzle-piece {
    position: absolute;
    transform-style: preserve-3d;
  }

  .puzzle-core {
    left: 36%;
    top: 32%;
    z-index: 8;
    display: grid;
    width: 29%;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 24px;
    background:
      linear-gradient(145deg, rgba(7, 21, 38, 0.96), rgba(22, 75, 119, 0.92)),
      #071526;
    box-shadow:
      0 28px 50px rgba(7, 21, 38, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.24);
    color: white;
    text-align: center;
    transform: translateZ(74px) rotateX(-58deg) rotateZ(12deg);
  }

  .puzzle-core strong {
    display: block;
    font-family: var(--font-display, inherit);
    font-size: clamp(1.9rem, 4vw, 3.3rem);
    font-weight: 900;
    line-height: 1;
  }

  .puzzle-core span {
    display: block;
    max-width: 12ch;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .puzzle-core .core-eyebrow {
    color: #64c8df;
    font-size: 0.66rem;
  }

  .connector {
    position: absolute;
    z-index: 1;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(100, 200, 223, 0), rgba(100, 200, 223, 0.9), rgba(119, 112, 201, 0.7));
    transform: translateZ(18px);
  }

  .connector-a {
    left: 15%;
    top: 50%;
    width: 46%;
    rotate: 13deg;
  }

  .connector-b {
    left: 39%;
    top: 21%;
    width: 42%;
    rotate: 76deg;
  }

  .connector-c {
    left: 43%;
    top: 62%;
    width: 42%;
    rotate: -20deg;
  }

  .puzzle-piece {
    z-index: 4;
    width: clamp(94px, 13vw, 148px);
    aspect-ratio: 1;
    filter: drop-shadow(0 24px 24px rgba(7, 21, 38, 0.16));
    transform: translateZ(48px);
  }

  .piece-face,
  .piece-depth {
    position: absolute;
    inset: 0;
    border-radius: 20px;
  }

  .piece-face {
    z-index: 2;
    display: grid;
    place-items: center;
    overflow: visible;
    border: 1px solid rgba(255, 255, 255, 0.72);
    background: var(--piece-bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.42),
      inset 0 -18px 28px rgba(7, 21, 38, 0.12);
  }

  .piece-depth {
    background: var(--piece-depth);
    transform: translate3d(12px, 14px, -28px);
  }

  .piece-tab,
  .piece-cut {
    position: absolute;
    width: 34%;
    aspect-ratio: 1;
    border-radius: 999px;
  }

  .piece-tab {
    background: var(--piece-bg);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.38);
  }

  .tab-right {
    right: -17%;
    top: 33%;
  }

  .tab-bottom {
    bottom: -17%;
    left: 33%;
  }

  .piece-cut {
    background: #f7fbfd;
    box-shadow: inset 0 9px 18px rgba(7, 21, 38, 0.12);
  }

  .cut-left {
    left: -17%;
    top: 33%;
  }

  .cut-top {
    left: 33%;
    top: -17%;
  }

  .piece-copy {
    position: relative;
    z-index: 3;
    display: grid;
    gap: 0.28rem;
    place-items: center;
    padding: 1rem;
    text-align: center;
    transform: rotateX(-58deg) rotateZ(12deg) translateZ(4px);
  }

  .piece-copy strong {
    color: var(--piece-ink);
    font-family: var(--font-display, inherit);
    font-size: clamp(1rem, 1.6vw, 1.3rem);
    font-weight: 900;
    line-height: 1;
  }

  .piece-copy span {
    color: var(--piece-muted);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .piece-a {
    left: 12%;
    top: 38%;
  }

  .piece-b {
    left: 34%;
    top: 10%;
  }

  .piece-c {
    left: 61%;
    top: 29%;
  }

  .piece-d {
    left: 29%;
    top: 59%;
  }

  .piece-e {
    left: 56%;
    top: 62%;
  }

  .navy {
    --piece-bg: linear-gradient(145deg, #0d2742, #164b77);
    --piece-depth: #071526;
    --piece-ink: #ffffff;
    --piece-muted: rgba(255, 255, 255, 0.74);
  }

  .blue {
    --piece-bg: linear-gradient(145deg, #1f64a0, #3f82f4);
    --piece-depth: #164b77;
    --piece-ink: #ffffff;
    --piece-muted: rgba(255, 255, 255, 0.78);
  }

  .cyan {
    --piece-bg: linear-gradient(145deg, #64c8df, #d6f5fa);
    --piece-depth: #2c8da3;
    --piece-ink: #071526;
    --piece-muted: rgba(7, 21, 38, 0.66);
  }

  .violet {
    --piece-bg: linear-gradient(145deg, #7770c9, #b9b4f0);
    --piece-depth: #4c478e;
    --piece-ink: #ffffff;
    --piece-muted: rgba(255, 255, 255, 0.78);
  }

  .warm {
    --piece-bg: linear-gradient(145deg, #f5f1e8, #ffc76b);
    --piece-depth: #d69b3f;
    --piece-ink: #071526;
    --piece-muted: rgba(7, 21, 38, 0.66);
  }

  @media (max-width: 1023px) {
    .puzzle-shell {
      position: relative;
      min-height: 430px;
    }

    .puzzle-stage {
      width: min(94vw, 520px);
    }
  }

  @media (max-width: 640px) {
    .puzzle-shell {
      min-height: 340px;
    }

    .puzzle-piece {
      width: clamp(78px, 24vw, 112px);
    }

    .puzzle-core {
      border-radius: 18px;
    }

    .piece-copy span,
    .puzzle-core span {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .puzzle-piece,
    .puzzle-core,
    .connector {
      opacity: 1 !important;
      transform: none !important;
    }

    .puzzle-stage {
      transform: rotateX(58deg) rotateZ(-12deg);
    }
  }
</style>
