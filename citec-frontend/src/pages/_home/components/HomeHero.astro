---
import { ArrowUpRight, ChevronRight } from "lucide-react";
import ParticlesToMap from "@/islands/ParticlesToMap";
---

<section class="home-hero text-primary-text" data-home-hero>
  <ParticlesToMap client:load />
9
  <div class="home-hero__content">
    <div class="home-hero__copy">
      <h1 class="home-hero__heading font-display !font-medium" data-home-hero-copy-item>
        <span>Impulsamos</span>
        <span class="home-hero__heading-accent">la innovación</span>
        <span class="home-hero__heading-line home-hero__heading-line--connects">
          <span class="home-hero__heading-line-copy">que conecta</span>
          <small class="home-hero__heading-country" aria-hidden="true">EL</small>
        </span>
      </h1>
      <p class="home-hero__subtitle" data-home-hero-copy-item>
        Conectamos empresas, academia y gobierno para transformar ideas en impacto real.
      </p>
      <div class="home-hero__actions" data-home-hero-copy-item>
        <a href="/unete/" class="citec-button citec-button--primary">
          Afiliate
          <ArrowUpRight className="home-hero__button-icon" size={18} strokeWidth={1.8} aria-hidden="true" />
        </a>
        <a href="/la-citec/" class="citec-button citec-button--secondary">
          Conoce la CITEC
          <ChevronRight className="home-hero__button-icon" size={18} strokeWidth={1.9} aria-hidden="true" />
        </a>
      </div>
      <span class="home-hero__rule" data-home-hero-copy-item></span>
    </div>
  </div>

  <script is:inline>
    const hero = document.currentScript?.closest("[data-home-hero]");

    if (hero instanceof HTMLElement) {
      hero.classList.add("home-hero--intro");

      window.setTimeout(() => {
        if (!hero.dataset.homeHeroSequenced) {
          hero.classList.remove("home-hero--intro");
        }
      }, 7000);
    }
  </script>
</section>
