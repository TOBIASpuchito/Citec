---
import Button from "@/components/ui/Button.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { pulsePosts } from "@/data/pulse";
import PulseCard from "@/components/sections/PulseCard.astro";

const [featured, ...rest] = pulsePosts;
---

<section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeader
        eyebrow="Pulse"
        title="Observatorio editorial para leer tecnologia con contexto."
        description="Briefs ejecutivos sobre regulacion, mercado y talento para que el ecosistema actue con mejor informacion."
      />
      <div data-reveal>
        <Button href="/pulse/" variant="secondary">Leer Pulse</Button>
      </div>
    </div>
    <div class="mt-10 grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
      <PulseCard post={featured} featured />
      <div class="grid gap-5">
        {rest.map((post) => <PulseCard post={post} />)}
      </div>
    </div>
  </div>
</section>
