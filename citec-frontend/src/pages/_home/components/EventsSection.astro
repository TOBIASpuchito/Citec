---
import EventCard from "@/components/sections/EventCard.astro";
import Button from "@/components/ui/Button.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { events } from "@/data/events";
---

<section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeader
        eyebrow="Actividad"
        title="Eventos y mesas para convertir conversacion en agenda."
        description="Foros, workshops y encuentros de alto valor para socios y aliados."
      />
      <div data-reveal>
        <Button href="/eventos/" variant="secondary">Ver eventos</Button>
      </div>
    </div>
    <div class="mt-10 grid gap-5">
      {events.map((event) => <EventCard event={event} />)}
    </div>
  </div>
</section>
