---
import LeadForm from "@/islands/LeadForm";
import CTASection from "@/components/sections/CTASection.astro";
import BenefitCard from "@/components/sections/BenefitCard.astro";
import Badge from "@/components/ui/Badge.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { benefits, membershipTiers, testimonials } from "@/data/benefits";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl, breadcrumbJsonLd, faqPageJsonLd } from "@/utils/seo";

const faqs = [
  [
    "Quien puede afiliarse?",
    "Empresas tecnologicas, equipos de innovacion, aliados institucionales y organizaciones vinculadas al ecosistema digital.",
  ],
  [
    "Que ocurre despues de enviar el formulario?",
    "CITEC revisa el interes, orienta la categoria de afiliacion y coordina una conversacion inicial.",
  ],
  [
    "Hay espacios para aliados estrategicos?",
    "Si. CITEC contempla alianzas para agenda publica, eventos, investigacion y desarrollo del ecosistema.",
  ],
] as const;
---

<BaseLayout
  title="Unete a CITEC"
  description="Beneficios claros, prueba social y una ruta directa para iniciar conversaciones de afiliacion o alianza."
  jsonLd={[
    breadcrumbJsonLd([
      { name: "Inicio", url: absoluteUrl("/") },
      { name: "Unete", url: absoluteUrl("/unete/") },
    ]),
    faqPageJsonLd(faqs.map(([question, answer]) => ({ question, answer }))),
  ]}
>
  <section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.72fr_0.55fr] lg:items-start">
      <div>
        <SectionHeader
          eyebrow="Valor para socios"
          title="Una afiliacion que combina criterio, red y presencia."
          description="CITEC ayuda a que las empresas tecnologicas ganen visibilidad, participen en agenda sectorial y accedan a informacion accionable."
        />
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {benefits.slice(0, 4).map((benefit) => <BenefitCard benefit={benefit} />)}
        </div>
      </div>
      <div data-reveal data-reveal-delay="0.08">
        <LeadForm client:visible />
      </div>
    </div>
  </section>

  <section class="bg-white/68 px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-3">
      {membershipTiers.map((tier) => (
        <article class="rounded-lg border border-citec-line/80 bg-white/86 p-6 shadow-[0_16px_38px_rgba(13,39,66,0.07)]" data-reveal>
          <Badge tone="cyan">{tier.name}</Badge>
          <h2 class="mt-6 font-display text-2xl font-black text-citec-ink">{tier.value}</h2>
          <p class="mt-4 text-sm leading-7 text-citec-ink-soft">{tier.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.55fr_0.8fr]">
      <SectionHeader
        eyebrow="Confianza"
        title="Validacion social para una comunidad en crecimiento."
        description="La narrativa de afiliacion debe apoyarse en voces del ecosistema y preguntas claras para tomar decision."
      />
      <div class="grid gap-5">
        {testimonials.map((item) => (
          <blockquote class="rounded-lg border border-citec-line/80 bg-white/86 p-6 shadow-[0_16px_38px_rgba(13,39,66,0.07)]" data-reveal>
            <p class="text-lg leading-8 text-citec-ink">“{item.quote}”</p>
            <footer class="mt-5 text-sm font-bold text-citec-ink-soft">{item.author} · {item.company}</footer>
          </blockquote>
        ))}
        <div class="grid gap-3">
          {faqs.map(([question, answer]) => (
            <details class="rounded-lg border border-citec-line bg-white/82 p-5" data-reveal>
              <summary class="cursor-pointer font-display text-lg font-black text-citec-ink">{question}</summary>
              <p class="mt-3 text-sm leading-7 text-citec-ink-soft">{answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Convierte tu participacion en presencia, agenda y oportunidades."
    description="El siguiente paso es abrir una conversacion con CITEC y elegir la ruta de afiliacion adecuada."
    primaryLabel="Completar solicitud"
    secondaryHref="/beneficios/"
    secondaryLabel="Comparar beneficios"
  />
</BaseLayout>
