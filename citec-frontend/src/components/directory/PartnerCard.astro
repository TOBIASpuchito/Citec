---
import Badge from "@/components/ui/Badge.astro";
import type { Partner } from "@/data/partners";

interface Props {
  partner: Partner;
  compact?: boolean;
}

const { partner, compact = false } = Astro.props;
---

<article class="group relative flex h-full flex-col rounded-lg border border-citec-line/80 bg-white/82 p-5 shadow-[0_16px_38px_rgba(27,36,48,0.07)] transition duration-300 ease-premium hover:-translate-y-1 hover:border-citec-cyan/55 hover:shadow-glass" data-reveal>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="grid h-12 w-12 shrink-0 place-items-center rounded-md bg-citec-ink font-black text-white shadow-soft">
        {partner.logo}
      </div>
      <div>
        <h3 class="font-display text-lg font-black leading-tight text-citec-ink">
          <a href={`/socios/${partner.slug}/`} class="after:absolute after:inset-0">
            {partner.name}
          </a>
        </h3>
        <p class="mt-1 text-sm font-semibold text-citec-ink-soft">{partner.city} · {partner.industry}</p>
      </div>
    </div>
    <Badge tone="cyan">{partner.category}</Badge>
  </div>

  <p class:list={["mt-5 text-sm leading-7 text-citec-ink-soft", compact && "line-clamp-3"]}>
    {partner.description}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {partner.benefits.slice(0, compact ? 2 : 3).map((benefit) => <Badge>{benefit}</Badge>)}
  </div>

  <div class="mt-auto flex items-center justify-between pt-6 text-xs font-bold uppercase tracking-[0.08em] text-citec-ink-soft">
    <span>{partner.clickCount} consultas</span>
    <span class="text-citec-blue">Ver perfil</span>
  </div>
</article>
