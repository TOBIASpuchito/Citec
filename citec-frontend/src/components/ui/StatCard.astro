---
interface Props {
  value: string;
  label: string;
  detail?: string;
  class?: string;
}

const { value, label, detail, class: className } = Astro.props;
---

<article class:list={["rounded-lg border border-citec-line/80 bg-white/76 p-5 shadow-[0_16px_42px_rgba(13,39,66,0.07)]", className]} data-reveal>
  <p class="font-display text-3xl font-black text-citec-ink sm:text-4xl">{value}</p>
  <h3 class="mt-2 text-sm font-black uppercase tracking-[0.08em] text-citec-blue">{label}</h3>
  {detail && <p class="mt-3 text-sm leading-6 text-citec-ink-soft">{detail}</p>}
</article>
