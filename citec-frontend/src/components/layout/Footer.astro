---
import BrandLogo from "@/components/ui/BrandLogo.astro";
import { footerNavigation, mainNavigation } from "@/data/navigation";
import { site } from "@/data/site";
---

<footer class="border-t border-white/10 bg-citec-indigo text-white">
  <div class="mx-auto grid w-full max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.2fr_0.8fr_0.8fr] lg:px-8">
    <div>
      <a href="/" class="inline-flex" aria-label="CITEC inicio">
        <BrandLogo layout="horizontal" tone="white" class="h-auto w-full max-w-[23rem]" />
      </a>
      <p class="mt-5 max-w-md text-sm leading-7 text-white/72">
        Un hub institucional para conectar empresas, regulacion, talento e innovacion en el ecosistema tecnologico ecuatoriano.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-extrabold text-white">Explorar</h2>
      <div class="mt-4 grid gap-2">
        {[...mainNavigation, ...footerNavigation].map((item) => (
          <a href={item.href} class="text-sm font-semibold text-white/72 transition hover:text-citec-lime">
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div>
      <h2 class="text-sm font-extrabold text-white">Contacto</h2>
      <div class="mt-4 space-y-2 text-sm font-medium text-white/72">
        <p>{site.address}</p>
        <a class="block transition hover:text-citec-lime" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="block transition hover:text-citec-lime" href={site.socials.linkedin}>LinkedIn</a>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 px-4 py-5 text-center text-xs font-semibold uppercase tracking-[0.12em] text-white/62">
    © {new Date().getFullYear()} CITEC. Hub digital institucional.
  </div>
</footer>
