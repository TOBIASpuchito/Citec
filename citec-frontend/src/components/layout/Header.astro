---
import { mainNavigation } from "@/data/navigation";
---

<header class="sticky top-0 z-50 border-b border-white/70 bg-white/78 backdrop-blur-xl">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-citec-ink focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
  >
    Saltar al contenido
  </a>
  <div class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-3" aria-label="CITEC inicio">
      <span class="grid h-10 w-10 place-items-center rounded-md bg-citec-ink text-sm font-black text-white shadow-soft transition duration-300 ease-premium group-hover:-translate-y-0.5">
        CT
      </span>
      <span class="leading-none">
        <span class="block font-display text-base font-black tracking-normal text-citec-ink">CITEC</span>
        <span class="mt-1 hidden text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-citec-ink-soft sm:block">Innovacion Ecuador</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegacion principal">
      {
        mainNavigation.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-2 text-sm font-semibold text-citec-ink-soft transition duration-300 ease-premium hover:bg-citec-mist hover:text-citec-ink"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a
        href="/unete/"
        class="rounded-md bg-citec-ink px-4 py-2 text-sm font-bold text-white shadow-soft transition duration-300 ease-premium hover:-translate-y-0.5 hover:bg-citec-navy"
      >
        Unete
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-md border border-citec-line bg-white text-citec-ink transition duration-300 ease-premium hover:bg-citec-mist" aria-label="Abrir menu">
        <span class="h-0.5 w-5 rounded-full bg-current shadow-[0_6px_0_current,0_-6px_0_current]"></span>
      </summary>
      <div class="glass-surface absolute right-0 mt-3 w-[min(18rem,calc(100vw-2rem))] rounded-lg p-2">
        {
          mainNavigation.map((item) => (
            <a href={item.href} class="block rounded-md px-3 py-3 text-sm font-semibold text-citec-ink-soft hover:bg-white">
              {item.label}
            </a>
          ))
        }
        <a href="/unete/" class="mt-1 block rounded-md bg-citec-ink px-3 py-3 text-sm font-bold text-white">
          Unete a CITEC
        </a>
      </div>
    </details>
  </div>
</header>
