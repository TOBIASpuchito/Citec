---
import Badge from "@/components/ui/Badge.astro";
import type { EventItem } from "@/data/events";

interface Props {
  event: EventItem;
}

const { event } = Astro.props;
const date = new Intl.DateTimeFormat("es-EC", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(new Date(`${event.date}T00:00:00`));
---

<article class="grid gap-5 rounded-lg border border-citec-line/80 bg-white/80 p-5 shadow-[0_16px_38px_rgba(13,39,66,0.07)] transition duration-300 ease-premium hover:-translate-y-1 hover:border-citec-blue/35 hover:shadow-glass sm:grid-cols-[9rem_1fr]" data-reveal>
  <div>
    <Badge tone="warm">{event.format}</Badge>
    <p class="mt-4 text-sm font-black uppercase tracking-[0.08em] text-citec-blue">{date}</p>
    <p class="mt-2 text-sm font-semibold text-citec-ink-soft">{event.city}</p>
  </div>
  <div>
    <h3 class="font-display text-xl font-black text-citec-ink">{event.title}</h3>
    <p class="mt-3 text-sm leading-7 text-citec-ink-soft">{event.description}</p>
  </div>
</article>
