---
import Badge from "@/components/ui/Badge.astro";
import type { Benefit } from "@/data/benefits";

interface Props {
  benefit: Benefit;
}

const { benefit } = Astro.props;
---

<article class="rounded-lg border border-citec-line/80 bg-white/80 p-5 shadow-[0_16px_38px_rgba(13,39,66,0.07)] transition duration-300 ease-premium hover:-translate-y-1 hover:border-citec-cyan/50 hover:shadow-glass" data-reveal>
  <div class="flex items-start justify-between gap-4">
    <Badge tone="blue">{benefit.tag}</Badge>
    <span class="font-display text-2xl font-black text-citec-cyan">{benefit.metric}</span>
  </div>
  <h3 class="mt-8 font-display text-xl font-black text-citec-ink">{benefit.title}</h3>
  <p class="mt-3 text-sm leading-7 text-citec-ink-soft">{benefit.description}</p>
</article>
