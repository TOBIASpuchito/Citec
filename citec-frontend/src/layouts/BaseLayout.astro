---
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SmoothScroll from "@/components/motion/SmoothScroll.astro";
import { site } from "@/data/site";
import {
  jsonLdGraph,
  organizationJsonLd,
  pageDescription,
  pageTitle,
  webPageJsonLd,
  websiteJsonLd,
  type JsonLdNode,
} from "@/utils/seo";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  bodyClass?: string;
  robots?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  jsonLd?: JsonLdNode | JsonLdNode[];
}

const {
  title,
  description,
  image,
  imageAlt,
  canonical,
  bodyClass,
  robots = "index, follow",
  ogType = "website",
  publishedTime,
  modifiedTime,
  section,
  jsonLd = [],
} = Astro.props;
const siteBase = Astro.site ?? new URL(site.url);
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteBase).toString();
const metaTitle = pageTitle(title);
const metaDescription = pageDescription(description);
const ogImage = new URL(image ?? site.ogImage, siteBase).toString();
const jsonLdNodes = [
  organizationJsonLd(),
  websiteJsonLd(),
  webPageJsonLd({
    title: metaTitle,
    description: metaDescription,
    url: canonicalUrl,
    image: ogImage,
  }),
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]),
];
const structuredData = jsonLdGraph(jsonLdNodes);
const sitemapUrl = new URL("/sitemap-index.xml", siteBase).toString();
const rssUrl = new URL("/rss.xml", siteBase).toString();
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.legalName} />
    <meta name="theme-color" content={site.themeColor} />
    <meta name="application-name" content={site.shortName} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={site.language} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} Pulse`} href={rssUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt ?? metaTitle} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {section && <meta property="article:section" content={section} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt ?? metaTitle} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </head>
  <body class:list={["text-primary-text antialiased", bodyClass]}>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <SmoothScroll />
  </body>
</html>
